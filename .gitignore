# ADNI EDA Project - Updated .gitignore
# Removed CSV and ZIP ignores to allow committing datasets as requested by USER

# Python cache & compiled files
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# macOS housekeeping
.DS_Store

# IDE settings
.vscode/
.idea/

# GitHub hard limit for a single file is 100MB.
# This archive exceeds that and will cause the push to fail.
archive/ADNI .zip
